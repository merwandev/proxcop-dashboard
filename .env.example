# Auth
AUTH_SECRET=             # openssl rand -base64 32
DISCORD_CLIENT_ID=       # Discord Developer Portal
DISCORD_CLIENT_SECRET=   # Discord Developer Portal
DISCORD_GUILD_ID=        # ID du serveur Proxcop

# Database
DATABASE_URL=            # Neon connection string (postgresql://...)

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=           # URL publique du bucket R2

# StockX API (OAuth2 + API Key)
STOCKX_API_KEY=              # StockX Developer Portal → API Key
STOCKX_CLIENT_ID=            # StockX Developer Portal → OAuth2 Client ID
STOCKX_CLIENT_SECRET=        # StockX Developer Portal → OAuth2 Client Secret
STOCKX_FALLBACK_URL=         # Callback URL: {APP_URL}/api/stockx/callback

# Vercel Analytics (optional — admin dashboard)
VERCEL_API_TOKEN=            # Vercel Settings → Tokens
# VERCEL_PROJECT_ID is auto-injected on Vercel deployments
# VERCEL_TEAM_ID is optional (for team projects)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
